{
  "name": "PDF Extractor PWA",
  "short_name": "PDF Extractor",
  "description": "Upload a PDF, preview extracted data, and download the processed result.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#08111f",
